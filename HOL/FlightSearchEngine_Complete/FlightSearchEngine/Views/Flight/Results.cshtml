@{
    ViewData["Title"] = "Search Results";
    var searchType  = ViewBag.SearchType as string ?? "FlightOnly";
    var source      = ViewBag.Source      as string ?? "";
    var destination = ViewBag.Destination as string ?? "";
    var persons     = ViewBag.Persons     is int p ? p : 0;

    bool isFlightOnly  = searchType == "FlightOnly";
    var flightResults  = Model as List<FlightSearchEngine.Models.FlightResult>;
    var packageResults = Model as List<FlightSearchEngine.Models.FlightHotelResult>;

    int resultCount = isFlightOnly
        ? (flightResults?.Count  ?? 0)
        : (packageResults?.Count ?? 0);
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/Flight/Index">Home</a></li>
        <li class="breadcrumb-item active">Search Results</li>
    </ol>
</nav>

<!-- Result Header -->
<div class="card border-0 rounded-4 shadow mb-4"
     style="background: linear-gradient(135deg,#0f3460,#533483);">
    <div class="card-body text-white py-4 px-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-1">
                    @if (isFlightOnly)
                    {
                        <i class="bi bi-airplane me-2"></i><text>Flight Results</text>
                    }
                    else
                    {
                        <i class="bi bi-building me-2"></i><text>Flight + Hotel Packages</text>
                    }
                </h2>
                <p class="mb-0 text-white-50">
                    <i class="bi bi-geo-alt me-1"></i>@source
                    <i class="bi bi-arrow-right mx-2"></i>@destination
                    &nbsp;|&nbsp;
                    <i class="bi bi-people me-1"></i>@persons person(s)
                </p>
            </div>
            <span class="badge bg-light text-dark fs-6 px-3 py-2">
                @resultCount result(s) found
            </span>
        </div>
    </div>
</div>

@if (resultCount == 0)
{
    <!-- No Results -->
    <div class="text-center py-5">
        <i class="bi bi-search display-1 text-muted"></i>
        <h3 class="mt-3 text-muted">No flights found</h3>
        <p class="text-muted">Try different source / destination cities.</p>
        <a href="/Flight/Index" class="btn btn-primary btn-lg mt-2">
            <i class="bi bi-arrow-left me-2"></i>Back to Search
        </a>
    </div>
}
else if (isFlightOnly && flightResults != null)
{
    <!-- Flight-Only Table -->
    <div class="card border-0 rounded-4 shadow">
        <div class="card-header bg-success text-white rounded-top-4 py-3">
            <h5 class="mb-0"><i class="bi bi-airplane me-2"></i>Available Flights</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Flight ID</th>
                            <th>Flight Name</th>
                            <th>Type</th>
                            <th>Source</th>
                            <th>Destination</th>
                            <th class="text-end">Total Cost</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rowNum = 1; }
                        @foreach (var flight in flightResults)
                        {
                            <tr>
                                <td class="text-muted">@rowNum++</td>
                                <td><span class="badge bg-secondary">@flight.FlightId</span></td>
                                <td class="fw-semibold">@flight.FlightName</td>
                                <td>
                                    @if (flight.FlightType == "International")
                                    {
                                        <span class="badge bg-primary">International</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark">Domestic</span>
                                    }
                                </td>
                                <td>@flight.Source</td>
                                <td>@flight.Destination</td>
                                <td class="text-end fw-bold text-success">
                                    ₹@flight.TotalCost.ToString("N2")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (!isFlightOnly && packageResults != null)
{
    <!-- Flight + Hotel Table -->
    <div class="card border-0 rounded-4 shadow">
        <div class="card-header py-3 rounded-top-4"
             style="background: linear-gradient(90deg,#f39c12,#e67e22);">
            <h5 class="mb-0 text-white">
                <i class="bi bi-building me-2"></i>Flight + Hotel Packages
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Flight ID</th>
                            <th>Flight Name</th>
                            <th>Source</th>
                            <th>Destination</th>
                            <th>Hotel</th>
                            <th class="text-end">Total Cost</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int pkgRow = 1; }
                        @foreach (var pkg in packageResults)
                        {
                            <tr>
                                <td class="text-muted">@pkgRow++</td>
                                <td><span class="badge bg-secondary">@pkg.FlightId</span></td>
                                <td class="fw-semibold">@pkg.FlightName</td>
                                <td>@pkg.Source</td>
                                <td>@pkg.Destination</td>
                                <td>
                                    <i class="bi bi-building-fill text-warning me-1"></i>@pkg.HotelName
                                </td>
                                <td class="text-end fw-bold" style="color:#e67e22;">
                                    ₹@pkg.TotalCost.ToString("N2")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Back Button -->
<div class="mt-4 text-center">
    <a href="/Flight/Index" class="btn btn-outline-primary btn-lg">
        <i class="bi bi-arrow-left me-2"></i>Back to Search
    </a>
</div>
